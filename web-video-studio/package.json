{
  "name": "web-video-studio",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "npm run electron:compile && electron .",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:build": "npm run build && npm run electron:compile && npm run electron:rebuild && electron-builder --mac --publish never && bash scripts/sign-dmg.sh",
    "electron:build:dmg": "npm run build && npm run electron:compile && npm run electron:rebuild && electron-builder --mac --publish never && bash scripts/sign-dmg.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/react": "^3.0.206",
    "@fal-ai/client": "^1.10.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "ai": "^6.0.204",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "fluent-ffmpeg": "^2.1.3",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "playwright": "^1.60.0",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.2.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4.3.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.webvideostudio.app",
    "productName": "WebVideo Studio",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "extraResources": [
      {
        "from": "../skills",
        "to": "skills"
      }
    ],
    "files": [
      ".next/**/*",
      "public/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@ffmpeg-installer/**"
    ]
  }
}

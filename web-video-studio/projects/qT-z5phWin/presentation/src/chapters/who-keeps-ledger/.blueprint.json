            "delay": 0,
            "duration": 0.6
          },
          {
            "target": "pos",
            "effect": "slideRight",
            "delay": 0.3,
            "duration": 0.6
          }
        ]
      }
    },
    {
      "narration": "权益证明不再是拼算力，而是根据你持有代币的数量和时间随机选验证者。持币越多，被选中概率越大。能耗大幅降低——以太坊等主流公链已经切换，运行稳定。能耗降低了99.95%。",
      "layout": {

        "mode": "composed",
        "layout": "stack",
        "regions": {
          "network": {
            "content": [
              {
                "primitive": "NetworkGraph",
                "params": {
                  "nodes": [
                    {
                      "id": "chief",
                      "label": "村长·唯一记账人",
                      "highlight": true
                    },
                    {
                      "id": "zhang",
                      "label": "张三"
                    },
                    {
                      "id": "li",
                      "label": "李四"
                    },
                    {
                      "id": "wang",
                      "label": "王五"
                    },
                    {
                      "id": "zhao",

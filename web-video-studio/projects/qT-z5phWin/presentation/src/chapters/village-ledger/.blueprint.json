{
  "chapterId": "village-ledger",
  "title": "全村的账本",
  "steps": [
    {
      "narration": "想象一下，你住在一个村子里。大家今天你帮我砌墙，明天我借你三斤鸡蛋。",
      "layout": {
        "mode": "template",
        "template": "hero-title",
        "variant": "centered",
        "slots": {
          "kicker": "一个故事",
          "title": "想象一下，你住在一个村子里。"
        },
        "overrides": {
          "backgroundStyle": "gradient-subtle"
        }
      }
    },
    {

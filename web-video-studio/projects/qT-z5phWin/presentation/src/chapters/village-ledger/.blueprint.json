        "animations": [
          {
            "target": "network",
            "effect": "fadeIn",
            "delay": 0,
            "duration": 1
          }
        ]
      }
    },
    {
      "narration": "可万一村长的账本被老鼠啃了呢？或者村长自己偷偷改了几笔账？整个村子就乱套了。",
      "layout": {
        "mode": "composed",
        "layout": "stack",
        "regions": {
